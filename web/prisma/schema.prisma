datasource db {
  provider = "postgresql"
}

generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

// -----------------------------------------------------------------------------
// 1. User & Access Control
// -----------------------------------------------------------------------------

model User {
  id            String     @id @default(uuid())
  clerkId       String     @unique // Auth ID from Clerk Auth
  email         String     @unique
  fullName      String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  // Relationships
  addresses     Address[]
  orders        Order[]
  wishlistItems Wishlist[]
  cartItems     CartItem[]
  reviews       Review[]

  @@index([clerkId])
  @@index([email])
}

model AdminUser {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
}

// -----------------------------------------------------------------------------
// 2. Catalog & Products
// -----------------------------------------------------------------------------

model Category {
  id          String    @id @default(uuid())
  name        String    @unique
  slug        String    @unique
  description String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relationships
  products    Product[]

  @@index([slug])
}

model Product {
  id               String         @id @default(uuid())
  name             String
  slug             String         @unique
  description      String         @db.Text
  basePrice        Decimal        @db.Decimal(10, 2)
  fabric           String         // e.g., Kanchipuram Silk, Banarasi Silk, Cotton
  colour           String         // e.g., Deep Crimson, Mustard Gold, Ivory
  occasion         String         // e.g., Bridal, Festive, Casual, Designer
  stock            Int            @default(0) // Inventory count
  careInstructions String         @db.Text
  deliveryInfo     String?        @db.Text
  returnPolicy     String?        @db.Text
  isActive         Boolean        @default(true)
  categoryId       String
  variantGroupId   String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  // Relationships
  category         Category       @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  images           ProductImage[]
  wishlistedBy     Wishlist[]
  cartItems        CartItem[]
  reviews          Review[]
  orderItems       OrderItem[]
  productSizes     ProductSize[]

  // Indexes for high-performance faceted filtering
  @@index([categoryId])
  @@index([fabric])
  @@index([colour])
  @@index([occasion])
  @@index([basePrice])
  @@index([isActive])
  @@index([variantGroupId])
}

// Per-size inventory for products that come in sizes (e.g. kurta sets).
// Products without sizes (sarees, jewellery) simply have no ProductSize rows.
model ProductSize {
  id        String   @id @default(uuid())
  productId String
  size      String   // e.g. "S", "M", "L", "XL", "XXL", "Free Size"
  stock     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, size])
  @@index([productId])
}

model ProductImage {
  id         String   @id @default(uuid())
  productId  String
  imageUrl   String   @db.Text
  publicId   String   // Cloudinary public asset identifier for deletion
  isPrimary  Boolean  @default(false) // Primary display image for thumbnails
  orderNum   Int      @default(0) // Ordering sequence for gallery slider
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Relationships
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([productId, isPrimary])
}

// -----------------------------------------------------------------------------
// 3. Customer Utilities (Wishlist & Reviews)
// -----------------------------------------------------------------------------

model Wishlist {
  id        String   @id @default(uuid())
  userId    String
  productId String
  createdAt DateTime @default(now())

  // Relationships
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  // A customer cannot wishlist the same product twice
  @@unique([userId, productId])
  @@index([userId])
}

model Review {
  id                 String   @id @default(uuid())
  userId             String
  productId          String
  rating             Int      // 1 to 5 star rating
  comment            String   @db.Text
  isVerifiedPurchase Boolean  @default(false)
  isApproved         Boolean  @default(false) // Moderation queue
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  // Relationships
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product            Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, isApproved])
  @@index([userId])
}

model CartItem {
  id        String   @id @default(uuid())
  userId    String
  productId String
  size      String   @default("") // "" for products without sizes (sarees/jewellery)
  quantity  Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relationships
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  // Same product can appear once per size (quantity handles multiples)
  @@unique([userId, productId, size])
  @@index([userId])
}

// -----------------------------------------------------------------------------
// 4. Cart & Checkout (Addresses & Orders)
// -----------------------------------------------------------------------------

model Address {
  id             String   @id @default(uuid())
  userId         String
  fullName       String
  phone          String
  alternatePhone String?
  line1          String
  line2          String?
  landmark       String?
  city           String
  state          String
  pincode        String   // 6-digit Pincode
  isDefault      Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relationships
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders         Order[]

  @@index([userId])
}

enum OrderStatus {
  PENDING
  PAID
  PROCESSING
  SHIPPED
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
}

model Order {
  id                  String      @id @default(uuid())
  orderNumber         String      @unique // E.g., DRP-20260608-XYZ123
  userId              String
  addressId           String
  totalAmount         Decimal     @db.Decimal(10, 2)
  status              OrderStatus @default(PENDING)
  razorpayOrderId     String      @unique // Generated by Razorpay
  shippingCarrier     String?     // E.g., Shiprocket, Delhivery
  shippingTrackingId  String?     // Tracking link from partner
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt

  // Relationships
  user                User        @relation(fields: [userId], references: [id], onDelete: Restrict)
  shippingAddress     Address     @relation(fields: [addressId], references: [id], onDelete: Restrict)
  orderItems          OrderItem[]
  payments            Payment[]

  @@index([userId])
  @@index([status])
  @@index([razorpayOrderId])
  @@index([createdAt])
}

model OrderItem {
  id              String   @id @default(uuid())
  orderId         String
  productId       String
  size            String   @default("") // Selected size at purchase ("" if not sized)
  quantity        Int      @default(1)
  priceAtPurchase Decimal  @db.Decimal(10, 2) // Snapshotted price at time of purchase
  createdAt       DateTime @default(now())

  // Relationships
  order           Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product         Product  @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([orderId])
  @@index([productId])
}

// -----------------------------------------------------------------------------
// 5. Payments (Razorpay Logs)
// -----------------------------------------------------------------------------

enum PaymentStatus {
  PENDING
  CAPTURED
  FAILED
  REFUNDED
}

model Payment {
  id                String        @id @default(uuid())
  orderId           String
  razorpayPaymentId String        @unique // E.g., pay_Hn83Yhn9U1
  razorpaySignature String        // Cryptographic proof returned by Razorpay
  amount            Decimal       @db.Decimal(10, 2)
  status            PaymentStatus @default(PENDING)
  method            String        // UPI, card, netbanking, wallet
  gatewayMessage    String?       // Errors returned by gateway
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  // Relationships
  order             Order         @relation(fields: [orderId], references: [id], onDelete: Restrict)

  @@index([orderId])
  @@index([razorpayPaymentId])
}

// -----------------------------------------------------------------------------
// 6. Marketing & Banners
// -----------------------------------------------------------------------------

enum BannerType {
  HERO
  FESTIVAL
  PROMOTIONAL
  FEATURED_STORY
  COLLECTION_CARD
  INSTAGRAM_POST
  WHY_CHOOSE_US
}

model Banner {
  id          String     @id @default(uuid())
  imageUrl    String     @db.Text
  publicId    String     // Cloudinary ID
  title       String?
  subtitle    String?
  description String?    @db.Text
  ctaText     String?
  accentColor String?
  redirectUrl String?    // Direct click redirection
  type        BannerType @default(HERO)
  isActive    Boolean    @default(true)
  orderNum    Int        @default(0) // Control slide ordering
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([isActive])
  @@index([type, isActive])
}
